{
  "name": "moodify-electron",
  "version": "1.0.0",
  "description": "Moodify Electron Desktop Client",
  "main": "main/index.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.moodify.app",
    "productName": "Moodify",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "files": [
      "main/**/*",
      "preload/**/*"
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  }
}
