generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./moodify.db"
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @default("")
  tags        String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lyrics      Lyrics[]
}

model Lyrics {
  id             Int      @id @default(autoincrement())
  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  content        String
  style          String?
  emotion        String?
  promptTemplate String?
  sunoPrompts    String?  @default("[]")  // 存储生成的suno prompt建议
  favorite       Boolean  @default(false)
  tags           String   @default("[]")
  createdAt      DateTime @default(now())

  // 关联的音乐
  musicTracks    MusicTrack[]

  @@index([projectId])
  @@index([favorite])
}

model MusicTrack {
  id            Int       @id @default(autoincrement())
  o3icsId       Int
  o3ics         Lyrics    @relation(fields: [o3icsId], references: [id], onDelete: Cascade)

  // Suno 相关
  taskId        String?   // Suno 任务ID
  sunoSongId    String?   // Suno 歌曲ID

  // 音频信息
  title         String
  audioUrl      String?
  videoUrl      String?
  coverImageUrl String?

  // 状态: pending, submitted, queued, in_progress, success, failure
  status        String    @default("pending")
  failReason    String?

  // 风格参数
  style         String?
  model         String?   // 使用的模型版本
  instrumental  Boolean   @default(false)

  // 元数据
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([o3icsId])
  @@index([taskId])
  @@index([status])
}

model Rule {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   // emotion, theme, style, rhyme, length, custom
  config      String   // 规则配置内容（关键词列表或其他配置）
  priority    Int      @default(5)
  isActive    Boolean  @default(true)

  // 元数据
  author      String?  // 规则作者
  version     String?  // 版本号
  tags        String   @default("[]")  // 标签数组
  description String?  // 规则描述

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model ApiLog {
  id        Int      @id @default(autoincrement())
  model     String
  input     String
  output    String
  tokens    Int
  cost      Float
  status    String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════
// 本地音乐库（方案 B / 方案 C 共用）
// ═══════════════════════════════════════════════════════════

model LocalArtist {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  coverPath   String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  songs       LocalSong[]
  albums      LocalAlbum[]
}

model LocalAlbum {
  id          Int         @id @default(autoincrement())
  title       String
  artistId    Int?
  artist      LocalArtist? @relation(fields: [artistId], references: [id])
  coverPath   String?
  year        Int?
  genre       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  songs       LocalSong[]

  @@unique([title, artistId])
}

model LocalSong {
  id          Int       @id @default(autoincrement())
  title       String
  artistName  String?
  albumName   String?
  genre       String?
  year        Int?
  duration    Int       @default(0)       // 秒
  trackNumber Int?

  // 文件路径（相对路径，存于 moodify_db/library/）
  audioPath   String?
  coverPath   String?
  lyricsPath  String?
  o3ics       String?   // 纯文本歌词

  // 播放信息
  playCount   Int       @default(0)
  favorite    Boolean   @default(false)

  // 文件哈希（用于去重）
  fileHash    String?   @unique

  // 关联
  artistId    Int?
  artist      LocalArtist? @relation(fields: [artistId], references: [id])
  albumId     Int?
  album       LocalAlbum?  @relation(fields: [albumId], references: [id])
  playlists   LocalPlaylistSong[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([artistName])
  @@index([title])
  @@index([favorite])
}

model LocalPlaylist {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  coverPath   String?
  songs       LocalPlaylistSong[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LocalPlaylistSong {
  id          Int           @id @default(autoincrement())
  playlistId  Int
  playlist    LocalPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  songId      Int
  song        LocalSong     @relation(fields: [songId], references: [id], onDelete: Cascade)
  position    Int           @default(0)

  @@unique([playlistId, songId])
}