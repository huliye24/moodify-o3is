generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./moodify.db"
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @default("")
  tags        String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lyrics      Lyrics[]
}

model Lyrics {
  id             Int      @id @default(autoincrement())
  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  content        String
  style          String?
  emotion        String?
  promptTemplate String?
  favorite       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([projectId])
  @@index([favorite])
}

model Rule {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // emotion, theme, style, rhyme, length
  config    String   // JSON 配置
  priority  Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model ApiLog {
  id        Int      @id @default(autoincrement())
  model     String
  input     String
  output    String
  tokens    Int
  cost      Float
  status    String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}